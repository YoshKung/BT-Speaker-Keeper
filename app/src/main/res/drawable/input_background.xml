<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#172026" />
            <stroke
                android:width="2dp"
                android:color="@color/accent" />
            <corners android:radius="6dp" />
            <padding
                android:bottom="12dp"
                android:left="14dp"
                android:right="14dp"
                android:top="12dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#172026" />
            <stroke
                android:width="1dp"
                android:color="#3A444A" />
            <corners android:radius="6dp" />
            <padding
                android:bottom="12dp"
                android:left="14dp"
                android:right="14dp"
                android:top="12dp" />
        </shape>
    </item>
</selector>
