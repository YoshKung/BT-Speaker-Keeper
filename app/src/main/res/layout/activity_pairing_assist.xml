<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:descendantFocusability="afterDescendants"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="42dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/focusable_panel"
        android:descendantFocusability="afterDescendants"
        android:orientation="vertical"
        android:padding="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Speaker pairing needed"
            android:textColor="@color/text_primary"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/pairing_assist_target_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Target speaker"
            android:textColor="@color/warning"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="กดปุ่ม Bluetooth หรือ Pair ที่ลำโพงค้างไว้จนไฟกระพริบ แล้วปล่อยให้แอปรอต่อให้อัตโนมัติ"
            android:textColor="@color/text_primary"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/pairing_assist_reason_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Speaker is not ready for Bluetooth pairing."
            android:textColor="@color/text_secondary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/pairing_assist_retry_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Waiting for speaker pairing mode."
            android:textColor="@color/text_primary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/pairing_assist_last_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="State: Unknown | Last error: None"
            android:textColor="@color/text_secondary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/pairing_assist_retry_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/focusable_button"
            android:focusable="true"
            android:text="Retry Pair Now"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <Button
            android:id="@+id/pairing_assist_main_button"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/focusable_button"
            android:focusable="true"
            android:text="Open Main Screen"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />
    </LinearLayout>
</LinearLayout>
