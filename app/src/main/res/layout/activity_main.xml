<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:descendantFocusability="afterDescendants"
    android:fillViewport="true"
    android:focusable="false"
    android:padding="32dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:descendantFocusability="afterDescendants"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BT Speaker Keeper"
            android:textColor="@color/text_primary"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Scan connected or paired Bluetooth devices, then press the speaker to toggle Auto Connect."
            android:textColor="@color/text_secondary"
            android:textSize="17sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/focusable_panel"
            android:descendantFocusability="afterDescendants"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Known Bluetooth devices"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/selected_speaker_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="No Auto Connect device selected"
                android:textColor="@color/text_secondary"
                android:textSize="17sp" />

            <Button
                android:id="@+id/scan_connected_devices_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/focusable_button"
                android:focusable="true"
                android:text="Scan Known Devices"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <LinearLayout
                android:id="@+id/connected_devices_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <Button
                android:id="@+id/connect_now_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/focusable_button"
                android:focusable="true"
                android:text="Connect Now"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />

            <Button
                android:id="@+id/repair_pair_now_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/focusable_button"
                android:focusable="true"
                android:text="Repair Pair Now"
                android:textAllCaps="false"
                android:textColor="@color/text_primary"
                android:textSize="18sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/focusable_panel"
                android:descendantFocusability="afterDescendants"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Required setup"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Nearby Devices"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/permission_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unknown"
                        android:textColor="@color/warning"
                        android:textSize="16sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/permission_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/focusable_button"
                    android:focusable="true"
                    android:text="Grant Permission"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Accessibility Service"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <TextView
                        android:id="@+id/accessibility_status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unknown"
                        android:textColor="@color/warning"
                        android:textSize="16sp" />
                </LinearLayout>

                <Button
                    android:id="@+id/accessibility_button"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/focusable_button"
                    android:focusable="true"
                    android:text="Open Accessibility Settings"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/focusable_panel"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Status log"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Last trigger"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/last_trigger_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Never"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Last connection state"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/last_state_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Unknown"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Last error"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/last_error_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="None"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Last successful connect"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/last_success_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Never"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:baselineAligned="false"
            android:orientation="horizontal"
            android:weightSum="2">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/focusable_panel"
                android:descendantFocusability="afterDescendants"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Safety controls"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/skip_playback_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/focusable_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Skip while playback: ON"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Max retry count"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/max_retry_minus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/max_retry_text"
                        android:layout_width="64dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="3"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/max_retry_plus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="+"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Cooldown"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/cooldown_minus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/cooldown_text"
                        android:layout_width="86dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="10 min"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/cooldown_plus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="+"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@drawable/focusable_panel"
                android:descendantFocusability="afterDescendants"
                android:orientation="vertical"
                android:padding="18dp">

                <Button
                    android:id="@+id/periodic_retry_button"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/focusable_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="Periodic retry: OFF"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="17sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Periodic retry interval"
                        android:textColor="@color/text_secondary"
                        android:textSize="16sp" />

                    <Button
                        android:id="@+id/periodic_interval_minus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="-"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/periodic_interval_text"
                        android:layout_width="92dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="60 min"
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/periodic_interval_plus_button"
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/focusable_button"
                        android:focusable="true"
                        android:text="+"
                        android:textColor="@color/text_primary"
                        android:textSize="22sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
